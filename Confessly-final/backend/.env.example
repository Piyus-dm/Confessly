# copy this file to .env and fill in real values — .env itself is gitignored

# ── mysql ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_USER=confessly
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=confessly

# ── auth secrets — generate strong random values for production ──
# e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
FLASK_SECRET_KEY=change-me

# ── urls ─────────────────────────────────────────────────────
# the public URL of THIS backend once deployed — must match the redirect
# URI registered in the Google/Facebook OAuth app consoles
BACKEND_URL=http://localhost:5000
# the public URL of the deployed frontend (for CORS + oauth redirects)
FRONTEND_URL=http://localhost:5173

# set to 1 once serving over https in production
COOKIE_SECURE=0

# ── google oauth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── facebook oauth ───────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── gmail smtp (password reset emails) ───────────────────────
# SMTP_PASSWORD must be a Gmail App Password, not your account password
SMTP_EMAIL=
SMTP_PASSWORD=

# ── cloudflare turnstile (bot protection) ────────────────────
CLOUDFLARE_SECRET_KEY=
VITE_CLOUDFLARE_SITE_KEY=

# set to 1 to skip turnstile verification in local dev only — never in prod
TURNSTILE_DEV_BYPASS=0

# set to 1 to disable the in-process trending-score scheduler (e.g. if you
# run it as a separate worker/cron instead)
DISABLE_SCHEDULER=0

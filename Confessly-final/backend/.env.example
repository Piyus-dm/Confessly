# copy to .env and fill in

MYSQL_HOST=localhost
MYSQL_USER=confessly
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=confessly

# generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
FLASK_SECRET_KEY=change-me

# has to match the redirect uri registered on google/facebook oauth
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# 1 once you're on https
COOKIE_SECURE=0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# needs a gmail app password, not your normal password
SMTP_EMAIL=
SMTP_PASSWORD=

CLOUDFLARE_SECRET_KEY=
VITE_CLOUDFLARE_SITE_KEY=

# skips turnstile check locally, don't set this in prod
TURNSTILE_DEV_BYPASS=0

# 1 if you're running the trending-score cron somewhere else
DISABLE_SCHEDULER=0
